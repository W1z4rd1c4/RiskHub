# RiskHub Frontend Environment Configuration
# Copy to .env and adjust for your environment

# =============================================================================
# API URL Configuration
# =============================================================================

# LOCAL DEVELOPMENT (backend running on host):
VITE_API_URL=http://localhost:8000/api/v1

# DOCKER (nginx proxies /api to backend - use relative path):
# VITE_API_URL=/api/v1

# LAN ACCESS (access from other devices, replace with your IP):
# VITE_API_URL=http://192.168.1.100:8000/api/v1
