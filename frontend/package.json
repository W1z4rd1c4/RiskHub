{
  "name": "riskhub-frontend",
  "private": true,
  "version": "1.0.0",
  "type": "module",
  "engines": {
    "node": "24.x"
  },
  "scripts": {
    "dev": "vite",
    "dev:lan": "vite --host",
    "build": "tsc -b && vite build",
    "lint": "eslint .",
    "quality:debt": "node scripts/quality/debt-budget.mjs",
    "i18n:inventory": "node scripts/i18n/inventory-ui-text.mjs",
    "i18n:scan": "node scripts/i18n/scan-hardcoded-ui.mjs",
    "i18n:validate:strict": "node scripts/i18n/validate-parity.mjs",
    "i18n:validate:usage": "node scripts/i18n/validate-key-usage.mjs",
    "cleanup:deadcode": "node scripts/cleanup/find-unreachable-modules.mjs",
    "i18n:test": "npm run i18n:validate:strict && npm run i18n:validate:usage && npm run i18n:scan && npm run cleanup:deadcode && npm run test:run -- src/i18n",
    "preview": "vite preview",
    "test": "vitest -c vitest.config.ts",
    "test:run": "vitest run -c vitest.config.ts",
    "test:coverage": "vitest run -c vitest.config.ts --coverage",
    "test:e2e": "playwright test -c playwright.config.ts",
    "e2e": "playwright test -c playwright.config.ts",
    "e2e:ui": "playwright test -c playwright.config.ts --ui",
    "e2e:headed": "playwright test -c playwright.config.ts --headed",
    "e2e:report": "playwright show-report ../tests/results/frontend/playwright/playwright-report",
    "e2e:business-logic": "playwright test -c playwright.config.ts ../tests/frontend/e2e/roles-access.spec.ts ../tests/frontend/e2e/access-scope.spec.ts ../tests/frontend/e2e/entity-ownership ../tests/frontend/e2e/department-access.spec.ts ../tests/frontend/e2e/permissions ../tests/frontend/e2e/approval-workflows ../tests/frontend/e2e/sensitive-fields ../tests/frontend/e2e/cross-department ../tests/frontend/e2e/activity-logging"
  },
  "dependencies": {
    "@azure/msal-browser": "^5.16.0",
    "@radix-ui/react-label": "^2.1.11",
    "@radix-ui/react-select": "^2.3.2",
    "@radix-ui/react-slot": "^1.2.4",
    "@radix-ui/react-tabs": "^1.1.16",
    "@tanstack/react-query": "^5.101.2",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "date-fns": "^4.4.0",
    "framer-motion": "^12.42.2",
    "i18next": "^26.3.4",
    "i18next-browser-languagedetector": "^8.2.0",
    "lucide-react": "^1.22.0",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-i18next": "^17.0.8",
    "react-is": "^19.2.7",
    "react-markdown": "^10.1.0",
    "react-router-dom": "^7.18.1",
    "recharts": "^3.9.1",
    "remark-gfm": "^4.0.1",
    "tailwind-merge": "^3.6.0",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@axe-core/playwright": "^4.12.1",
    "@eslint/js": "^10.0.1",
    "@playwright/test": "^1.61.1",
    "@tailwindcss/typography": "^0.5.20",
    "@testing-library/dom": "^10.4.1",
    "@testing-library/jest-dom": "^6.9.1",
    "@testing-library/react": "^16.3.1",
    "@testing-library/user-event": "^14.6.1",
    "@types/node": "^26.0.1",
    "@types/react": "^19.2.17",
    "@types/react-dom": "^19.2.3",
    "@vitejs/plugin-react": "^6.0.3",
    "@vitest/coverage-v8": "^4.1.9",
    "autoprefixer": "^10.5.2",
    "eslint": "^10.6.0",
    "eslint-plugin-react-hooks": "7.1.1",
    "eslint-plugin-react-refresh": "^0.5.3",
    "globals": "^17.7.0",
    "jsdom": "^29.1.1",
    "msw": "^2.14.6",
    "postcss": "^8.5.16",
    "tailwindcss": "^4.3.2",
    "tailwindcss-animate": "^1.0.7",
    "typescript": "~6.0.3",
    "typescript-eslint": "^8.62.1",
    "vite": "^8.1.2",
    "vitest": "^4.0.16"
  }
}
