{
  "pathPatterns": [
    "**/*.test.ts",
    "**/*.test.tsx",
    "**/__tests__/**",
    "**/test/**",
    "**/*.d.ts",
    "src/i18n/**",
    "src/types/**"
  ],
  "tokenPatterns": [
    "^RiskHub$",
    "^AD Emulator$",
    "^CZK$",
    "^EUR$",
    "^DORA$",
    "^GDPR$",
    "^ISO\\s?27001$",
    "^[A-Z0-9_:-]{2,}$",
    "^[-+*/→•|:()\\[\\]{}.,\\s0-9]+$"
  ]
}
