# RiskHub unified production configuration (non-secret values only)
#
# Copy to /etc/riskhub/riskhub.env and replace all placeholder values.
# Secret values live in /etc/riskhub/secrets/.

PUBLIC_URL=https://riskhub.example.com
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=11111111-1111-1111-1111-111111111111
# Leave blank for client-secret mode. Set the thumbprint and the PEM private key file for certificate mode.
ENTRA_CLIENT_CERTIFICATE_THUMBPRINT=
# Optional: directory extension short name for Entra-owned business-role metadata.
# The RiskHub app registration must also expose this as an optional ID-token claim.
# Example Graph field: extension_<appIdWithoutDashes>_riskhubBusinessRole
ENTRA_BUSINESS_ROLE_ATTRIBUTE_NAME=
BOOTSTRAP_ADMIN_EMAIL=admin@example.com
BOOTSTRAP_CRO_EMAIL=cro@example.com

# Optional advanced settings
API_WORKERS=4
FRONTEND_BIND_PORT=80
