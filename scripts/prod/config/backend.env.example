# Phase 500 backend.env template (external PostgreSQL + redis container)
#
# Copy to a secure location on the host (example):
#   cp scripts/prod/config/backend.env.example /etc/riskhub/backend.env
#
# Notes:
# - This install path assumes PostgreSQL is external (no DB container is started).
# - Redis is required in production when DEBUG=false (backend startup guard enforces this).
# - Docker --env-file does NOT expand ${VARS}. If you want REDIS_URL derived from REDIS_PASSWORD,
#   leave REDIS_URL empty and let the Phase 500 scripts compute and inject it.

# Required: production hardening
DEBUG=false
MOCK_AUTH_ENABLED=false
AUTH_MODE=microsoft_sso

# Required: secrets
SECRET_KEY=CHANGE_ME_THIS_MUST_BE_AT_LEAST_32_CHARS

# Required: external PostgreSQL
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://riskhub:CHANGE_ME@postgres.example.com:5432/riskhub

# Required: CORS allowlist (JSON array, no "*")
CORS_ORIGINS=["https://riskhub.example.com"]

# Optional: Trusted hosts allowlist (JSON array). If empty, backend derives from CORS_ORIGINS.
ALLOWED_HOSTS=["riskhub.example.com"]

# Required: Redis (Phase 500 scripts run redis container with this password)
REDIS_PASSWORD=CHANGE_ME
# Optional: If empty, scripts compute: redis://:<REDIS_PASSWORD>@redis:6379/0
REDIS_URL=

# Required: Microsoft Entra ID (SSO)
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_SECRET=CHANGE_ME_ENTRA_CLIENT_SECRET

# Optional: SSO behavior controls
ENTRA_JIT_PROVISIONING_ENABLED=true
# ENTRA_ALLOWED_EMAIL_DOMAINS=["yourdomain.com"]

# Optional: Scheduler enablement is controlled per-container (scripts set this; do not hardcode unless you know why)
# ENABLE_SCHEDULER=false

# Optional: Bootstrap initial privileged users (pre-provision by email to avoid SSO lockout)
BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
BOOTSTRAP_ADMIN_ROLE=admin
BOOTSTRAP_ADMIN_ACCESS_SCOPE=global

# Optional: Bootstrap initial CRO user (recommended)
BOOTSTRAP_CRO_EMAIL=cro@yourcompany.com
BOOTSTRAP_CRO_ACCESS_SCOPE=global
