# Internal docker backend.env template.
#
# This file is rendered by scripts/deploy.sh for the docker target. Operators should
# edit /etc/riskhub/riskhub.env and /etc/riskhub/secrets/* instead of maintaining this
# file directly.
#
# Notes:
# - PostgreSQL is external.
# - Redis is required in production when DEBUG=false.
# - Secret material is referenced via *_FILE paths and mounted into the container.

# Required: production hardening
DEBUG=false
MOCK_AUTH_ENABLED=false
AUTH_MODE=microsoft_sso

# Required: secret file references
SECRET_KEY_FILE=/etc/riskhub/secrets/secret_key
DATABASE_URL_FILE=/etc/riskhub/secrets/database_url
ENTRA_CLIENT_SECRET_FILE=/etc/riskhub/secrets/entra_client_secret
REDIS_URL_FILE=/etc/riskhub/runtime/redis_url

# Required: CORS allowlist (JSON array, no "*")
CORS_ORIGINS=["https://riskhub.example.com"]

# Optional: Trusted hosts allowlist (JSON array). If empty, backend derives from CORS_ORIGINS.
ALLOWED_HOSTS=["riskhub.example.com"]

# Required: Microsoft Entra ID (SSO)
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Optional: SSO behavior controls
ENTRA_JIT_PROVISIONING_ENABLED=true
# ENTRA_ALLOWED_EMAIL_DOMAINS=["yourdomain.com"]

# Optional: Scheduler enablement is controlled per-container (scripts set this; do not hardcode unless you know why)
# ENABLE_SCHEDULER=false

# Optional: Bootstrap initial privileged users (pre-provision by email to avoid SSO lockout)
BOOTSTRAP_ADMIN_EMAIL=admin@yourcompany.com
BOOTSTRAP_ADMIN_ROLE=admin
BOOTSTRAP_ADMIN_ACCESS_SCOPE=global

# Optional: Bootstrap initial CRO user (recommended)
BOOTSTRAP_CRO_EMAIL=cro@yourcompany.com
BOOTSTRAP_CRO_ACCESS_SCOPE=global
