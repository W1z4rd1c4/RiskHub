# Phase 500 frontend.env template (nginx SPA + /api proxy)
#
# Copy to a secure location on the host (example):
#   cp scripts/prod/config/frontend.env.example /etc/riskhub/frontend.env

# Required: host port published for frontend container
FRONTEND_HOST_PORT=80

# Optional: container port (nginx default is 80)
FRONTEND_CONTAINER_PORT=80

# Optional: documentation only (nginx config is static for same-host topology)
SERVER_NAME=riskhub.example.com

