# Internal docker frontend.env template (nginx SPA + /api proxy)
#
# This file is rendered by ./scripts/deploy.sh for the docker target. Operators should
# edit /etc/riskhub/riskhub.env instead of maintaining this file directly.
# Deprecated orchestration wrappers in scripts/prod/ must not be used for operator deployment.

# Required: host port published for frontend container
FRONTEND_HOST_PORT=80

# Optional: container port (nginx default is 80)
FRONTEND_CONTAINER_PORT=80

# Optional: documentation only (nginx config is static for same-host topology)
SERVER_NAME=riskhub.example.com
