# RiskHub Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# REQUIRED FOR PRODUCTION - These MUST be set before deployment
# =============================================================================

# Database connection string
# Format: postgresql+asyncpg://user:password@host:port/database
DATABASE_URL=postgresql+asyncpg://riskhub:your-secure-password@localhost:5432/riskhub

# JWT secret key - MUST be a strong random string (min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-min-32-chars-generate-with-python

# PostgreSQL credentials (for docker-compose.prod.yml)
POSTGRES_USER=riskhub
POSTGRES_PASSWORD=your-secure-database-password
POSTGRES_DB=riskhub

# =============================================================================
# SECURITY SETTINGS
# =============================================================================

# Enable debug mode (MUST be false in production)
DEBUG=false

# Authentication mode:
# - password: internal username/password login
# - microsoft_sso: Microsoft Entra ID SSO only (required when DEBUG=false)
# - hybrid_dev: demo login + optional SSO (development only)
AUTH_MODE=microsoft_sso

# Enable mock authentication via X-Mock-User-Id header
# WARNING: NEVER enable in production - allows impersonation!
MOCK_AUTH_ENABLED=false

# =============================================================================
# MICROSOFT ENTRA ID (SSO) - REQUIRED WHEN AUTH_MODE=microsoft_sso
# =============================================================================

# Entra tenant ID (GUID)
ENTRA_TENANT_ID=00000000-0000-0000-0000-000000000000

# Entra application (client) ID (GUID)
ENTRA_CLIENT_ID=00000000-0000-0000-0000-000000000000

# Optional: restrict logins to specific email domains (JSON array)
# ENTRA_ALLOWED_EMAIL_DOMAINS=["yourdomain.com"]
# Legacy alias (still supported): ENTRA_ALLOWED_DOMAINS=["yourdomain.com"]

# Just-in-time provisioning: create a local user on first successful SSO login.
# Set to false to require users to be pre-provisioned (admin/directory sync).
ENTRA_JIT_PROVISIONING_ENABLED=true

# Optional: JWT time claim leeway (seconds) to tolerate clock skew
ENTRA_CLOCK_SKEW_SECONDS=60

# Optional: override OIDC discovery URL (defaults to tenant v2.0 discovery)
# ENTRA_OIDC_DISCOVERY_URL=https://login.microsoftonline.com/<tenant_id>/v2.0/.well-known/openid-configuration

# =============================================================================
# NETWORK / CORS CONFIGURATION
# =============================================================================

# CORS origins - JSON array of allowed origins
# In production, set to your actual domain(s)
CORS_ORIGINS=["https://riskhub.yourdomain.com"]

# Trusted hosts - Host header allowlist (production hardening)
# If not set, allowed hosts are derived from CORS_ORIGINS.
ALLOWED_HOSTS=["riskhub.yourdomain.com","localhost"]

# Redis - REQUIRED in production (DEBUG=false) for multi-worker rate limiting + login lockout
# If using docker-compose.prod.yml Redis service, set:
#   REDIS_PASSWORD=...
#   REDIS_URL=redis://:${REDIS_PASSWORD}@redis:6379/0
REDIS_PASSWORD=your-redis-password
REDIS_URL=redis://:your-redis-password@localhost:6379/0

# =============================================================================
# EXTERNAL SERVICES
# =============================================================================

# AD Emulator URL for directory sync (optional)
# If not set, AD sync features will be disabled
AD_EMULATOR_URL=http://localhost:8001/api/v1

# Webhook secret for AD Emulator webhooks (HMAC-SHA256 signature verification)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
WEBHOOK_SECRET=your-webhook-secret-for-hmac-verification

# =============================================================================
# LOGGING CONFIGURATION
# =============================================================================

# Log level: DEBUG, INFO, WARNING, ERROR, CRITICAL
LOG_LEVEL=INFO

# Log directory (relative to backend root or absolute path)
LOG_DIR=./logs

# Application log rotation settings
APP_LOG_ROTATION_SIZE_MB=10
APP_LOG_RETENTION_COUNT=7

# Audit log rotation settings (security-sensitive, keep longer)
AUDIT_LOG_ROTATION_SIZE_MB=50
AUDIT_LOG_RETENTION_COUNT=30

# =============================================================================
# DOCKER-SPECIFIC SETTINGS (for docker-compose.prod.yml)
# =============================================================================

# Compose project name (affects container naming)
COMPOSE_PROJECT_NAME=riskhub

# =============================================================================
# DEVELOPMENT SETTINGS (remove or comment out for production)
# =============================================================================

# IMPORTANT: Demo Mode Requirements
# ----------------------------------
# For demo login (/auth/demo-login/{user_id}) to work, ALL of these must be set:
#   DEBUG=true
#   MOCK_AUTH_ENABLED=true
#   AUTH_MODE=hybrid_dev
# The demo login endpoint is completely disabled in production for security.
# Rate limit: 10 demo logins per minute per IP (vs 5 for regular login).

# Example development settings:
# DEBUG=true
# MOCK_AUTH_ENABLED=true
# AUTH_MODE=hybrid_dev
# SECRET_KEY=dev-secret-key-not-for-production-use
# DATABASE_URL=postgresql+asyncpg://riskhub:riskhub_dev@localhost:5432/riskhub
# CORS_ORIGINS=["http://localhost:5173","http://localhost:80"]
