# RiskHub Backend Environment Configuration
# Copy this file to .env and customize for your environment

# =============================================================================
# REQUIRED FOR PRODUCTION
# =============================================================================

# Database connection string
DATABASE_URL=postgresql+asyncpg://user:password@localhost:5432/riskhub

# JWT secret key - MUST be a strong random string (min 32 chars)
# Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
SECRET_KEY=your-secret-key-here-min-32-chars

# =============================================================================
# DEVELOPMENT / DEMO SETTINGS (remove or set to false for production)
# =============================================================================

# Enable debug mode (verbose logging, relaxed checks)
DEBUG=true

# Enable mock authentication via X-Mock-User-Id header
# WARNING: This allows anyone to impersonate any user - NEVER enable in production!
MOCK_AUTH_ENABLED=true

# =============================================================================
# OPTIONAL SETTINGS
# =============================================================================

# CORS origins (comma-separated, no spaces)
# CORS_ORIGINS=["http://localhost:5173","http://localhost:3000"]

# AD Emulator URL for directory sync
AD_EMULATOR_URL=http://localhost:8001/api/v1

# Webhook secret for AD Emulator webhooks (HMAC-SHA256 signature verification)
# WEBHOOK_SECRET=your-webhook-secret
