# RiskHub Backend Environment Configuration
# Copy this to .env and adjust values for your environment

# =============================================================================
# DATABASE - Choose ONE of the following configurations:
# =============================================================================

# Option A: Use Docker's Postgres (RECOMMENDED for consistency)
# Start with: docker-compose up -d db
DATABASE_URL=postgresql+asyncpg://riskhub:riskhub_dev@localhost:5432/riskhub

# Option B: Docker-internal (used automatically by docker-compose, don't change)
# DATABASE_URL=postgresql+asyncpg://riskhub:riskhub_dev@db:5432/riskhub

# =============================================================================
# DEVELOPMENT SETTINGS
# =============================================================================
DEBUG=true
MOCK_AUTH_ENABLED=true
SECRET_KEY=dev-secret-key-not-for-production-use

# =============================================================================
# CORS - Add your frontend origins
# =============================================================================
CORS_ORIGINS=["http://localhost:5173","http://localhost:3000","http://localhost:80"]

# =============================================================================
# AD EMULATOR (Optional)
# =============================================================================
AD_EMULATOR_URL=http://localhost:8001/api/v1
WEBHOOK_SECRET=
